---
import { Image } from 'astro:assets';
import { siteData } from '@data/siteData';
import HeroImage from "@assets/technician.png"
import { withBase } from '../utils/basePath';

const appBase = process.env.ASTRO_BASE;
const withBasePath = (path: string) => withBase(path, appBase);
---

<section class="relative min-h-screen flex items-center justify-center bg-linear-to-br from-slate-900 via-slate-800 to-slate-900 pt-20 overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          {siteData.tagline}
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed">
          Your trusted local team for quick, transparent repairs and quality pre-owned phones backed by warranty.
        </p>

        <!-- Mobile Hero Media -->
        <div class="lg:hidden mb-8">
          <div class="relative rounded-2xl overflow-hidden border border-slate-700 bg-slate-800 shadow-xl">
            <div class="aspect-[16/10]">
              <Image
                src={HeroImage}
                alt="Technician repairing a smartphone"
                width={900}
                height={560}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/70 via-slate-900/20 to-transparent"></div>
            <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between gap-3">
              <span class="inline-flex items-center gap-2 rounded-full bg-orange-500/95 text-white text-xs font-semibold px-3 py-1.5">
                <i class="ri-flashlight-line"></i>
                Same-Day Repairs
              </span>
              <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/85 text-gray-100 text-xs font-semibold px-3 py-1.5 border border-slate-600">
                <i class="ri-shield-check-line text-orange-400"></i>
                Certified Pre-Owned Phones
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center lg:justify-start mb-12">
          <a
            href={withBasePath('/phones')}
            class="bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 rounded-lg font-bold text-lg transition-all transform inline-flex items-center justify-center gap-3"
          >
            View Available Phones
            <i class="ri-arrow-right-line"></i>
          </a>
          <a
            href={siteData.addressMapLink}
            class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-slate-900 px-8 py-4 rounded-lg font-bold text-lg transition-all inline-flex items-center justify-center gap-3"
          >
            Visit Our Store
            <i class="ri-map-pin-line"></i>
          </a>
        </div>

        <!-- Stats -->
        <!-- <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-orange-500 mb-2">10+</div>
            <div class="text-gray-300 text-sm md:text-base">Years Serving Ottawa</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-orange-500 mb-2">Same Day</div>
            <div class="text-gray-300 text-sm md:text-base">Most Repairs Completed</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-4xl md:text-5xl font-bold text-orange-500 mb-2">6 Mo.</div>
            <div class="text-gray-300 text-sm md:text-base">Repair Warranty</div>
          </div>
        </div> -->
      </div>

      <!-- Hero Image -->
      <div class="hidden lg:block">
        <div class="relative">
          <div class="aspect-square rounded-2xl overflow-hidden bg-slate-800 border-2 border-slate-700 shadow-2xl">
            <Image
              src={HeroImage}
              alt="Mobile phone repair service"
              width={800}
              height={800}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-orange-500 p-6 rounded-xl shadow-xl">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center">
                <i class="ri-trophy-line text-2xl text-orange-500"></i>
              </div>
              <div>
                <div class="text-white font-bold text-lg">Trusted Local Service</div>
                <div class="text-white/80 text-sm">Ottawa Mobile Experts</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce hidden lg:block">
    <i class="ri-arrow-down-line text-2xl text-white"></i>
  </div>
</section>
