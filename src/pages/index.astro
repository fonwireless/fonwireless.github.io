---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import { siteData } from '../data/siteData';
import { withBase } from '../utils/basePath';

const appBase = process.env.ASTRO_BASE;
const withBasePath = (path: string) => withBase(path, appBase);
---

<Layout title={`Mobile Repair Shop in Ottawa | ${siteData.name}`} description={siteData.description}>
  <Hero />
  <Features />
  
  <!-- CTA Section -->
  <section class="py-20 bg-linear-to-r from-orange-500 to-orange-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Need Fast Phone Repair in Ottawa?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Get a quick quote, visit our shop, or browse available used phones today.
      </p>
      <a
        href={withBasePath('/phones')}
        class="inline-flex items-center justify-center gap-3 bg-white text-orange-500 hover:bg-slate-100 px-8 py-4 rounded-lg font-bold text-lg transition-all transform hover:scale-105 shadow-lg"
      >
        View Available Phones
        <i class="ri-arrow-right-line"></i>
      </a>
    </div>
  </section>
</Layout>
